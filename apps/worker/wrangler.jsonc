{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "foodpicker-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-09",
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Room"],
    },
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOM",
        "class_name": "Room",
      },
    ],
  },
  "vars": {
    "WS_BASE_URL": "wss://foodpicker-worker.ruben-hedstrom.workers.dev",
  },
}
